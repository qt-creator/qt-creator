<externaltool id="vi">
    <description>Opens the current file in vi</description>
    <displayname>Edit with vi</displayname>
    <category>Text</category>
    <executable>
        <path>%{Settings:Tools:Terminal:FilePath}</path>
        <arguments>%{Settings:Tools:Terminal:RunInTerminalArgs} vi "%{CurrentDocument:FilePath}" +%{CurrentDocument:Row}</arguments>
        <workingdirectory>%{CurrentDocument:Path}</workingdirectory>
    </executable>
</externaltool>
