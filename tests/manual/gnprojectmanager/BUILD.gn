group("default") {
  deps = [
    "//src/app",
  ]
}

group("scripts") {
  testonly = true
  deps = [ ":run" ]
}
action("run") {
  script = "//build/run_app.py"
  outputs = [ "$root_out_dir/run.stamp" ]
  deps = [ "//src/app" ]
  args = [
    rebase_path("$root_out_dir/run.stamp", root_build_dir),
    rebase_path("$root_out_dir/app", root_build_dir),
    "arg1",
    "arg2",
  ]
}
